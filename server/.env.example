PORT=3000

# Required for /admin: password login + signed session cookies (use a long random string in production)
ADMIN_PASSWORD=aquablue123
SESSION_SECRET=thisisasecretkey

# Optional: comma-separated allowed browser origins (e.g. https://yoursite.com).
# Leave unset to reflect the request origin (works for many single-site setups).
# CORS_ORIGIN=https://yoursite.com

# Optional: SQLite file path (default: server/data/socutesy.db)
# SQLITE_PATH=

# Railway (or any host with a persistent disk): mount a volume, then set e.g. DATA_DIR=/data
# → DB: $DATA_DIR/socutesy.db, uploads: $DATA_DIR/uploads
# Overrides: SQLITE_PATH (full file path), UPLOAD_ROOT (uploads folder only)
# DATA_DIR=/data

# Upload limits
# UPLOAD_MAX_MB=15
# UPLOAD_MAX_FILES=30

# Node: set in production so session cookies are HTTPS-only
# NODE_ENV=production

# Optional: serve the Vite build from one process (path to frontend/dist). Same-origin for /api + admin.
# Build first: cd ../frontend && npm run build
# STATIC_DIR=../frontend/dist
